#!/usr/bin/env python3
"""
openclaw-guard — CLI management tool for the OpenClaw PreTool Guard system.

Manages guard rules, allowlists, block logs, and repo-specific overrides
for the pretool-guard hook that blocks dangerous command patterns.

Subcommands:
  rules           List all guard rules
  blocks          Show recent block log entries
  toggle          Toggle a rule's enabled state
  level           Set block_level for a rule
  allow           Add a command to the allowlist
  deny            Remove a command from all allowlists
  config          Browse/edit configuration (interactive with gum)
  defaults        Set global default block_level
  reset           Reset guard-rules.json to factory defaults
"""

import argparse
import json
import os
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, List, Optional


# ============================================================================
# Constants
# ============================================================================

VERSION = "1.0.0"

PLUGIN_DIR = Path(
    os.environ.get(
        "OPENCLAW_PLUGIN_DIR",
        str(Path.home() / ".openclaw" / "extensions" / "openclaw-lacp-fusion"),
    )
)

CONFIG_PATH = PLUGIN_DIR / "config" / "guard-rules.json"
BLOCK_LOG_PATH = PLUGIN_DIR / "logs" / "guard-blocks.jsonl"


# ============================================================================
# Factory Default Config
# ============================================================================


